# EvezArt OpenClaw — Environment Variables
# Copy to .env and fill in your keys

# AI Providers (get free keys at respective sites)
GROQ_API_KEY=gsk_your_groq_key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
CEREBRAS_API_KEY=csk-your_cerebras_key
HUGGING_FACE_ACCESS_TOKEN=hf_your_hf_token

# Gateway
GATEWAY_TOKEN=your-secret-gateway-token
PORT=8080

# GitHub sync (optional, enables spine cloud backup)
GITHUB_TOKEN=github_pat_your_token

# Telegram (optional, enables alerts)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
